<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="true">
  <code><![CDATA[turtles-own [opinion uncertainty opinion-list uncertainty-list focus?]

to setup
  clear-all
  ask patches [set pcolor white]
  create-turtles N [
    ifelse (random-float 1 > fraction_extremists) [
      set opinion new_opinion
      set uncertainty uncertainty_moderates
    ] [
      set opinion one-of list -1 1
      set uncertainty uncertainty_extremists
    ] 
    set opinion-list (list opinion)
    set uncertainty-list (list uncertainty)
    set focus? false
  ]
  visualize
  reset-ticks
end

to go
  ; rolling world updates
  ask turtles [ 
    if (length opinion-list = max-pxcor + 1) [ 
      set opinion-list butfirst opinion-list 
      set uncertainty-list butfirst uncertainty-list 
    ] 
  ] ;; cut oldest values for "rolling" opinion list
  ; update opinions
  ask turtles [ update_opinion_uncertainty ]
  ; rolling world updates
  ask turtles [ 
    set opinion-list lput opinion opinion-list 
    set uncertainty-list lput uncertainty uncertainty-list
  ]
  visualize
  tick
end


to update_opinion_uncertainty
  let other_turtle one-of other turtles
  set opinion opinion + opinion_change opinion [opinion] of other_turtle uncertainty [uncertainty] of other_turtle
  if uncertainty_change? [
    set uncertainty uncertainty + uncertainty_change opinion [opinion] of other_turtle uncertainty [uncertainty] of other_turtle
  ]
end

to-report new_opinion
  ; create a new opinion confined between -1 and +1 from a random number from normal or uniform distribution
  report max list -1 ( min list 1 ((random-float 2) - 1) )
end

to-report opinion_change [o1 o2 u1 u2]
  report max list (-1 - o1) ( min list (1 - o1) (mu * (kernel-value o1 o2 u1 u2) * (o2 - o1)) )
end

to-report uncertainty_change [o1 o2 u1 u2]
  report max list (-1 - o1) ( min list (1 - o1) (mu * (kernel-value o1 o2 u1 u2) * (u2 - u1)) )
end

to-report kernel-value [o1 o2 u1 u2]
  report (ifelse-value 
    kernel = "Relative Agreement" [ifelse-value ((overlap o1 o2 u1 u2) > u2) [(overlap o1 o2 u1 u2) / u2 - 1] [0]]
    kernel = "Bounded Confidence" [ifelse-value abs (o1 - o2) < u1 [1] [0]]
      [1])
end

to-report overlap [o1 o2 u1 u2]
  report min list (o1 + u1) (o2 + u2) - max list (o1 - u1) (o2 - u2)
end

;; VISUALIZATION

to visualize
  ;; let turtles move with their opinion trajectories from left to right across the world drawing trajectories or coloring patches
  clear-drawing
  ask turtles [
    pen-up
    setxy 0 (scale-to-max-pycor (item 0 opinion-list))
;    setxy 0 item 0 opinion-list
    pen-down
  ]
  let t-counter 0
  while [ t-counter < (length ( [opinion-list] of turtle 0 )) ] [
    foreach sort turtles [ turt -> ;; with foreach for drawing always in the same order
      ask turt [
        set color colorcode_uncertainty (item t-counter uncertainty-list) uncertainty_moderates
;        setxy t-counter item t-counter opinion-list          
        setxy t-counter (scale-to-max-pycor (item t-counter opinion-list)) 
      ]
    ]
    set t-counter t-counter + 1
  ]
end

to-report scale-to-max-pycor [x]
  ;; confines values to certain bounds, values exceeding the bound are set to the bound
  ;; x is the value to confine, ma is the absolute value of the maximal values to display
  ;; scales x such that it coincides with the bounds maxpycor and -maxpycor
  ; let y max list (min list x (ma - 0.0000000001)) (- ma + 0.0000000001)
  report x * max-pycor ;; set to 0.999999999 instead of 1 to make these opinions visible in opinion histogram
end

to-report colorcode_uncertainty [x max_x]
  report hsb (120 * (x / max_x)) 100 100
end]]></code>
  <widgets>
    <view x="10" wrappingAllowedX="false" y="184" frameRate="30.0" minPycor="-30" height="293" showTickCounter="true" patchSize="6.17413" fontSize="10" wrappingAllowedY="false" width="958" tickCounterLabel="ticks" maxPycor="30" updateMode="1" maxPxcor="200" minPxcor="0"></view>
