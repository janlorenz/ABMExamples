  <previewCommands>setup repeat 75 [ go ]</previewCommands>
  <experiments>
    <experiment name="SimulationExperiment_1" repetitions="1" sequentialRunOrder="true" runMetricsEveryStep="false" timeLimit="1">
      <setup>setup</setup>
      <go>run_until_world_full</go>
      <metrics>
        <metric>cum_bias</metric>
        <metric>cum_diversity</metric>
        <metric>cum_fragmentation</metric>
      </metrics>
      <constants>
        <enumeratedValueSet variable="alpha">
          <value value="0.1"></value>
          <value value="0.2"></value>
          <value value="0.3"></value>
          <value value="0.4"></value>
        </enumeratedValueSet>
        <steppedValueSet variable="theta" first="0" step="0.01" last="0.3"></steppedValueSet>
        <steppedValueSet variable="rho" first="0" step="0.02" last="1"></steppedValueSet>
        <enumeratedValueSet variable="M">
          <value value="3.5"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="N">
          <value value="500"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="iterations_per_tick">
          <value value="50"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="spinup_tick">
          <value value="51"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="motivated_cognition">
          <value value="false"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="lambda">
          <value value="0.5"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="k">
          <value value="10"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="theta_as">
          <value value="&quot;idiosyncrasy probability&quot;"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="initial_groupspread">
          <value value="0"></value>
        </enumeratedValueSet>
